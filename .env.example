# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/bookease?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Resend
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=BookEase <noreply@yourdomain.com>

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
